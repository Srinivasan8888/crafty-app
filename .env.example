# ---------------------------------------------------------------------------
# Crafty — environment template
# Copy this to .env (or .env.local) and fill in real values for local dev.
# Values listed here are placeholders only; never commit real secrets.
# ---------------------------------------------------------------------------

# Postgres connection string. Local dev typically points at a docker or brew
# Postgres instance with a `crafty_dev` database created up front.
DATABASE_URL="postgresql://USER@localhost:5432/crafty_dev"

# Auth — set DEV_AUTH=true to bypass Descope and auto-log in as the dev user
# identified below. Set to false (or remove) to use real Descope.
#
# IMPORTANT: this flag is intentionally NOT NEXT_PUBLIC_*. It must never be
# exposed to the client bundle, and lib/auth.ts will hard-stop the process
# if DEV_AUTH=true under NODE_ENV=production.
DEV_AUTH=true
DEV_USER_EMAIL=you@example.com
DEV_USER_NAME=Your Name

# Descope — copy from https://app.descope.com/settings/project (Project ID is
# public, Management Key is server-side). Webhook secret is what you set when
# configuring the Audit Webhook connector in the Descope console.
#
# Required dashboard work before this works:
#   1. Add custom JWT claims for `email` and `name` (Project Settings → Custom Claims)
#   2. Customize the sign-in / sign-up flows in the Flow Editor
#   3. Create an Audit Webhook connector → /api/webhooks/descope
NEXT_PUBLIC_DESCOPE_PROJECT_ID=P_placeholder
DESCOPE_MANAGEMENT_KEY=K_placeholder
DESCOPE_WEBHOOK_SECRET=placeholder

# City routing
DEFAULT_CITY=bengaluru
NEXT_PUBLIC_DEFAULT_CITY=bengaluru
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Upstash Redis (rate limiting). Create a free database at upstash.com and
# paste the REST URL + token here. Required for /api/* mutation endpoints.
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token
# T7 — SiC admin (Week 4 deliverable per PRD §12.4 + design doc risk #1).
SIC_ADMIN_EMAIL=
SIC_ADMIN_NAME=

# T5 — PostHog analytics (PRD §16.2).
# PostHog's current docs call this PROJECT_TOKEN. The app also accepts the
# older NEXT_PUBLIC_POSTHOG_KEY name for compatibility.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_placeholder
NEXT_PUBLIC_POSTHOG_KEY=phc_placeholder
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# T-Email — Resend transactional email (PRD §15).
RESEND_API_KEY=re_placeholder
RESEND_FROM=Crafty <hello@crafty.app>

# T-Sentry — error monitoring (PRD §20).
SENTRY_DSN=https://placeholder@sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://placeholder@sentry.io/0

# T-Cron — shared secret for /api/cron/* endpoints.
CRON_SECRET=

# T-Storage — pluggable image storage backend.
# STORAGE_DRIVER=local (default, public/uploads) | s3 (Replit Object Storage /
# Cloudflare R2 / AWS S3). When s3, set the STORAGE_S3_* vars.
STORAGE_DRIVER=local
STORAGE_S3_ENDPOINT=
STORAGE_S3_REGION=auto
STORAGE_S3_BUCKET=
STORAGE_S3_PUBLIC_BASE=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=

# T-Razorpay — payments for featured listings (V2.0).
# Get keys from https://dashboard.razorpay.com → Settings → API Keys.
# Webhook secret is set per-webhook in Razorpay's webhook config UI.
RAZORPAY_KEY_ID=rzp_placeholder
RAZORPAY_KEY_SECRET=placeholder
RAZORPAY_WEBHOOK_SECRET=placeholder

# V3 — Crafty Pro subscription plan IDs. Razorpay requires plans to be
# pre-created in their dashboard → Subscriptions → Plans. Paste the
# `plan_xxxx` IDs here once you've created the monthly (₹299) and annual
# (₹2,999) plans. While `plan_placeholder`, /api/subscriptions returns 503.
RAZORPAY_PLAN_MONTHLY=plan_placeholder
RAZORPAY_PLAN_ANNUAL=plan_placeholder

# V3 Tier 4 — background job queue. Default `redis://placeholder` keeps the
# queue in inline mode (handlers run in-process at enqueue time). To enable
# real background processing, set this to a real Redis URL — Upstash Redis
# (https://upstash.com), Railway Redis, or any self-hosted Redis 6+ — then
# `bun add bullmq` and run a worker process.
REDIS_URL=redis://placeholder

# V3 Tier 4 — Anthropic API key for AI-assisted flag triage. The /admin
# "AI triage" button calls Claude to classify flagged listings. Placeholder
# = the endpoint returns an UNCLEAR stub verdict.
ANTHROPIC_API_KEY=sk-ant-placeholder
